# Database
DB_HOST=127.0.0.1
DB_PORT=1800
DB_USER=postgres
DB_PASSWORD=mypg123abc
CONFIG_DB=mypet_config

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=6
REDIS_PASSWORD=

# JWT
JWT_SECRET=mypet_agent_secret_key_2024
JWT_EXPIRATION=86400

# Upload
UPLOAD_ROOT=./uploads

# LLM (defaults)
LLM_PROVIDER=deepseek
LLM_MODEL_NAME=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Agent
AGENT_LOCK_TIMEOUT=60
AGENT_LOCK_WAIT_TIMEOUT=60
HITL_TIMEOUT=600

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8083
